  "description": "Polyimide flex sensor strip with 2x VCNL4040 proximity/ambient light sensors, individual VDD filtering, IR LED bypass caps, and FPC tail connector to rigid base. Bends at center to angle sensors ~2 degrees outward for direction discrimination.",
  "blocks": {
    "sensor_1": {
      "description": "VCNL4040 proximity sensor 1 (Side A) with VDD supply filtering",
      "sheet": "sensor-flex.kicad_sch",
      "components": [
        "IC1",
        "R11",
        "C7"
      ],
      "notes": "Side A faces the back of the hoop (-2 degrees). VDD supplied through R11 (22 ohm series filter) with C7 (0.1uF) local bypass. I2C and INT routed to FPC1 pins 2-4 (channel 1). All VCNL4040 share address 0x60 \u2014 isolated by PCA9546A mux on rigid base."
    },
    "sensor_2": {
      "description": "VCNL4040 proximity sensor 2 (Side B) with VDD supply filtering",
      "sheet": "sensor-flex.kicad_sch",
      "components": [
        "IC2",
        "R10",
        "C6"
      ],
      "notes": "Side B faces the front of the hoop (+2 degrees). VDD supplied through R10 (22 ohm series filter) with C6 (0.1uF) local bypass. I2C and INT routed to FPC1 pins 6-8 (channel 2)."
    },
    "power": {
      "description": "IR LED supply bypass capacitors on 3.3V rail",
      "sheet": "sensor-flex.kicad_sch",
      "components": [
        "C4",
        "C8"
      ],
      "notes": "Each 2.2uF cap handles pulsed current draw from VCNL4040 IR LED emission. Placed on the 3.3V rail near the LED anode pin (pin A) of each sensor."
    },
    "connector": {
      "description": "FPC tail connector for mating with ZIF connector on rigid base",
      "sheet": "sensor-flex.kicad_sch",
      "components": [
        "FPC1"
      ],
      "notes": "10-pin FPC tail with 1.0mm pitch. Pins 1-4: power + sensor 1 I2C/INT. Pin 5: GND shield. Pins 6-8: sensor 2 I2C/INT. Pins 9-10: GND mechanical."
    }
  },

  "description": "Custom power management PCB replacing the DWEII USB-C module. Provides USB PD negotiation (STUSB4500), Li-ion battery charging and power path management (BQ24195), boost conversion to +5V (MT3608), and 3.3V LDO regulation (LR1801). Outputs +5V, +3.3V, and status signals to the main board via connectors.",
  "blocks": {
    "usb_pd": {
      "description": "USB-C connector with PD negotiation and input protection",
      "sheet": "usb_pd.kicad_sch",
      "components": [
        "USBC1",
        "F1",
        "U1",
        "U2",
        "R1",
        "R2",
        "R3",
        "R4",
        "R5",
        "C1",
        "C2",
        "C14"
      ],
      "notes": "STUSB4500 handles USB PD voltage/current negotiation via I2C. 5.1k CC pull-downs set UFP/sink role per USB-C spec. VBUS protected by fuse F1, producing Protected_VBUS rail. I2C bus shared with BQ24195 charger on battery_mgmt sheet. Note: STUSB4500 CC1/CC2 pins tied to GND in current schematic - may need connection to USB-C CC lines for PD negotiation."
    },
    "battery_mgmt": {
      "description": "Li-ion battery charging, power path management, and system voltage output",
      "sheet": "battery_mgmt.kicad_sch",
      "components": [
        "U3",
        "J1",
        "Q1",
        "L1",
        "TH1",
        "R6",
        "R7",
        "R8",
        "C3",
        "C4",
        "C5",
        "C6",
        "C7",
        "C8",
        "C13",
        "TP1",
        "TP2",
        "TP3",
        "TP4",
        "TP5",
        "TP6"
      ],
      "notes": "BQ24195 provides integrated charging and power path management. Accepts Protected_VBUS from USB, charges Li-ion battery via VBAT, outputs VSYS for downstream regulators. PMOS Q1 with R7/R8 bias network provides battery reverse polarity protection. NTC thermistor monitors battery temperature. R6 (2.7k) sets input current limit. 6 test points for debug access to key voltage rails and I2C bus."
    },
    "power_dist": {
      "description": "Voltage regulation: boost converter for +5V rail and LDO for +3.3V rail",
      "sheet": "power_dist.kicad_sch",
      "components": [
        "U4",
        "U5",
        "D1",
        "L2",
        "R9",
        "R10",
        "R11",
        "C9",
        "C10",
        "C11",
        "C12",
        "TP7",
        "TP8",
        "TP9"
      ],
      "notes": "MT3608 boost converter steps up VSYS to the +5V net. Note: feedback divider R10=47k/R9=10k targets ~3.42V per Vout=0.6*(1+47/10), not 5V - resistor values may need adjustment. LR1801 LDO provides 3.3V directly from VSYS. R11 bootstraps LR1801 enable from its own output. Both rails feed CN1."
    },
    "connectors": {
      "description": "Output connectors for power rails and status/control signals to main board",
      "sheet": "connectors.kicad_sch",
      "components": [
        "CN1",
        "J3",
        "J4"
      ],
      "notes": "CN1 (Molex MicroFit 3-pin) carries +5V, GND, +3.3V power to main board. J3 (JST SH 2-pin) provides I2C bus access for configuring STUSB4500 and BQ24195. J4 (JST SH 5-pin) passes USB attach/alert and charge status/interrupt/power-good signals to the main board for firmware monitoring."
    }
  },

  "description": "Sensor rigid base PCB with PCA9546A I2C mux routing upstream bus from main board to 2 downstream VCNL4040 sensor channels via ZIF FPC connector, with address configuration jumpers, wired-OR interrupt combining, and per-channel I2C pull-ups",
  "blocks": {
    "i2c_mux": {
      "description": "PCA9546A 4-channel I2C multiplexer with address configuration and reset",
      "sheet": "sensor-rigid.kicad_sch",
      "components": [
        "U1",
        "JP3",
        "JP4",
        "R3",
        "R12",
        "R13",
        "R14"
      ],
      "notes": "A2 permanently pulled high via R12. A0/A1 default low (R13/R14) but can be set high via solder jumpers JP4/JP3. Default address with no jumpers: A2=1,A1=0,A0=0. Three boards differentiated by JP3/JP4 configuration."
    },
    "connectors": {
      "description": "Board-to-board connectors: JST-SH input from main PCB and ZIF FPC output to flex sensor strip",
      "sheet": "sensor-rigid.kicad_sch",
      "components": [
        "J1",
        "FPC1"
      ],
      "notes": "J1 carries upstream I2C (SDA/SCL), 3.3V power, GND, and combined interrupt from main board. FPC1 fans out to 2 independent I2C channels + 2 interrupt lines for the two VCNL4040 sensors on the flex strip."
    },
    "i2c_pull_ups": {
      "description": "I2C bus pull-up resistors for upstream and downstream channels",
      "sheet": "sensor-rigid.kicad_sch",
      "components": [
        "R1",
        "R2",
        "R6",
        "R7",
        "R8",
        "R9"
      ],
      "notes": "R1/R2 are upstream (main bus side) SDA/SCL pull-ups. R8/R9 are sensor 1 channel pull-ups, R6/R7 are sensor 2 channel pull-ups. All 4.7k\u03a9 to 3.3V. PCA9546A isolates upstream from downstream, so each side needs its own pull-ups."
    },
    "interrupts": {
      "description": "Wired-OR interrupt combining circuit merging two sensor interrupts into one line",
      "sheet": "sensor-rigid.kicad_sch",
      "components": [
        "D2",
        "D3",
        "R5"
      ],
      "notes": "D2 and D3 (BAT54S Schottky diodes) combine INT1 and INT2 into a single active-low interrupt line routed to J1 pin 5. R5 (8.2k\u03a9) pulls the combined line high. Either sensor asserting INT pulls the line low through its diode."
    },
    "power": {
      "description": "Power supply bypass capacitors and indicator LED",
      "sheet": "sensor-rigid.kicad_sch",
      "components": [
        "C1",
        "C2",
        "D1",
        "R4"
      ],
      "notes": "C1 (2.2\u00b5F) and C2 (0.1\u00b5F) provide bulk and high-frequency bypass for the 3.3V rail. D1 LED with R4 (1k\u03a9) current limiter indicates power presence."
    },
    "test_points": {
      "description": "Debug test points for probing power and signal lines",
      "sheet": "sensor-rigid.kicad_sch",
      "components": [
        "TP1",
        "TP2",
        "TP3",
        "TP4",
        "TP5"
      ],
      "notes": "TP1=3.3V, TP2=GND, TP3=upstream SDA, TP4=upstream SCL, TP5=combined INT."
    }
  },

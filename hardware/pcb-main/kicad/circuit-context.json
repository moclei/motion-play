  "description": "ESP32-S3 based sensor controller main PCB with USB-C power input, 3.3V regulation, I2C multiplexer for 3 sensor modules, and WS2812B LED strip driver with level shifting",
  "blocks": {
    "power": {
      "description": "Power supply subsystem: USB-C input, reverse-polarity protection, 3.3V LDO regulation",
      "sheet": "motion-play-main.kicad_sch",
      "components": [
        "J2",
        "D1",
        "U1",
        "C1",
        "C2",
        "TP_5V1",
        "TP_3V1",
        "TP_GND1"
      ],
      "notes": "DWEII power module is a temporary development solution with battery charging. Long-term plan is custom USB-C + buck regulator. D1 Schottky provides reverse-polarity protection with ~0.3V drop."
    },
    "mcu": {
      "description": "Main system controller (ESP32-S3) and GPIO breakout test points",
      "sheet": "motion-play-main.kicad_sch",
      "components": [
        "U2",
        "TPIO1",
        "TPIO2",
        "TPIO3",
        "TPIO10",
        "TPIO11",
        "TPIO12",
        "TPIO13",
        "TPIO16",
        "TPIO17",
        "TPIO18",
        "TPIO21",
        "TPIO43",
        "TPIO44"
      ],
      "notes": "T-Display-S3 dev board used temporarily. Long-term plan is bare ESP32-S3 integrated into main PCB. GPIO 1-3, 17, 18, 21 are unused breakouts for future expansion."
    },
    "i2c_mux": {
      "description": "TCA9548A I2C multiplexer subsystem with pull-ups and decoupling",
      "sheet": "tca9548A_subsystem.kicad_sch",
      "components": [
        "U4",
        "R6",
        "R28",
        "R29",
        "C9",
        "C10"
      ],
      "notes": "Routes single upstream I2C bus to 3 downstream channels for sensor boards. Address 0x70 (all address pins grounded). R28/R29 are upstream pull-ups; downstream pull-ups are on sensor boards."
    },
    "sensor_connectors": {
      "description": "JST-SH connectors carrying I2C and interrupt signals to three sensor modules",
      "sheet": "motion-play-main.kicad_sch",
      "components": [
        "J4",
        "J5",
        "J6"
      ],
      "notes": "Each 5-pin connector provides 3.3V power, GND, I2C SDA/SCL (from TCA9548A channel), and interrupt. Wired to sensor rigid base PCBs which have PCA9546A local muxes."
    },
    "led_controller": {
      "description": "LED strip driver with level shifting, power protection, and current sensing",
      "sheet": "led_controller.kicad_sch",
      "components": [
        "IC1",
        "F1",
        "R27",
        "C7",
        "C8",
        "J3"
      ],
      "notes": "Drives 72-LED WS2812B strip. SN74AHCT125 shifts 3.3V data to 5V. Power path: +5V -> F1 (3A fuse) -> R27 (0.1 ohm sense) -> +5V_TO_LEDS. J3 is on root sheet but functionally part of this block."
    }
  },
